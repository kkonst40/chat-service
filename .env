# ENV
ENV=dev
PORT=8080
SSO_URL=ssoapp:50051
REQUEST_TIMEOUT=5 # seconds
LOGIN_CACHE_TTL=12 # hours
WSCONNS_PER_IP=10

# DB
DB_HOST=chatdb
DB_PORT=5432
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_DB=app_db

# Redis
REDIS_HOST=chatredis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka
KAFKA_HOST=kafka
KAFKA_PORT=9092

IP_RATE_LIMIT=5 # per second
IP_RATE_MAX_BURST=15 # per second
IP_RATE_CLEANUP_INTERVAL=60 # seconds
IP_RATE_IDLE_LIFETIME=180 # seconds